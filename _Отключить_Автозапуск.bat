@echo off
chcp 65001 >nul
title Отключение автозапуска Запрета

:: Проверка на запуск от имени администратора
net session >nul 2>&1
if %errorLevel% neq 0 (
    echo =======================================================
    echo ОШИБКА: НЕТ ПРАВ АДМИНИСТРАТОРА
    echo =======================================================
    echo Пожалуйста, нажмите по этому файлу ПРАВОЙ КНОПКОЙ МЫШИ
    echo и выберите "Запуск от имени администратора".
    echo =======================================================
    pause
    exit /b
)

echo Удаление задачи из Планировщика задач Windows...

:: Удаляем задачу
schtasks /delete /tn "Zapret_AutoStart" /f

if %errorLevel% equ 0 (
    echo.
    echo =======================================================
    echo УСПЕШНО! 
    echo Автозапуск Запрета отключен.
    echo =======================================================
) else (
    echo.
    echo Возникла ошибка при удалении задачи (возможно, она не была создана).
)

pause
