@echo off
chcp 65001 >nul
title Установка автозапуска Запрета

:: Проверка на запуск от имени администратора
net session >nul 2>&1
if %errorLevel% neq 0 (
    echo =======================================================
    echo ОШИБКА: НЕТ ПРАВ АДМИНИСТРАТОРА
    echo =======================================================
    echo Пожалуйста, нажмите по этому файлу ПРАВОЙ КНОПКОЙ МЫШИ
    echo и выберите "Запуск от имени администратора".
    echo =======================================================
    pause
    exit /b
)

echo Создание задачи в Планировщике задач Windows...

:: Создаем задачу, которая выполняется при входе пользователя, с максимальными (админскими) правами
schtasks /create /tn "Zapret_AutoStart" /tr "\"%~dp0general (ALT2).bat\"" /sc onlogon /rl highest /f

if %errorLevel% equ 0 (
    echo.
    echo =======================================================
    echo УСПЕШНО! 
    echo Теперь general (ALT2).bat будет запускаться автоматически 
    echo при включении ПК от имени администратора (без окон подтверждения UAC).
    echo =======================================================
    echo ПРИМЕЧАНИЕ: Если вы переместите или переименуете папку с Запретом,
    echo вам нужно будет снова запустить этот файл, чтобы обновить путь.
) else (
    echo.
    echo Возникла ошибка при создании задачи.
)

pause
